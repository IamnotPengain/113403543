<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Overlapping Shapes</title>
    <style>
        /* Container settings to allow for absolute positioning of shapes */
        .container {
            position: relative;
            width: 300px;
            height: 200px;
            margin: 50px auto; /* Centers the whole drawing on page */
        }

        /* Styling for the blue rectangle */
        .rectangle {
            width: 200px;
            height: 150px;
            background-color: blue;
            border: 3px solid black;
            
            position: absolute;
            top: 25px;
            left: 0;
            z-index: 1;
        }

        .circle {
            width: 120px;
            height: 120px;
            background-color: yellow;
            border: 4px solid red;
            border-radius: 50%;
            
            position: absolute;
            top: 40px;
            left: 110px;
            z-index: 2;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="rectangle"></div>
        <div class="circle"></div>
    </div>

</body>
</html>